# Database
DATABASE_URL=postgresql://user:password@localhost:5432/bpb

# JWT
JWT_SECRET=your-jwt-secret-here

# Claude API
CLAUDE_API_KEY=your-claude-api-key

# S3 Storage
S3_BUCKET=bpb-files
S3_REGION=us-east-1
S3_ACCESS_KEY=your-access-key
S3_SECRET_KEY=your-secret-key

# Server
PORT=3000
NODE_ENV=development

# T-Bank Payments
TBANK_TERMINAL_KEY=your-terminal-key
TBANK_PASSWORD=your-tbank-password
TBANK_API_URL=https://rest-api-test.tinkoff.ru/v2
# Production: TBANK_API_URL=https://securepayments.tinkoff.ru/v2
